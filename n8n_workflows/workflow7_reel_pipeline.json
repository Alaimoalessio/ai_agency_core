      "position": [3000, 600],
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_ADMIN_CHAT_ID }}",
        "text": "=🎬 *Reel pubblicato!*\n\nPersonaggio: {{ $('Prepara URL Pubblico').item.json.character_name }}\nProvider: {{ $('Prepara URL Pubblico').item.json.provider }}\nPiattaforme: {{ $('Prepara URL Pubblico').item.json.publish_ig ? 'Instagram ✓' : '' }} {{ $('Prepara URL Pubblico').item.json.publish_tiktok ? 'TikTok ✓' : '' }}\n\n{{ $('Prepara URL Pubblico').item.json.caption_base }}",
        "additionalFields": { "parse_mode": "Markdown" }
      }
    },
    {
      "id": "wf7-db-failed",
      "name": "DB: reel_status = failed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1000, 850],
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/images?reel_task_id=eq.{{ $('Verifica Callback').item.json.task_id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"reel_status\": \"failed\", \"error_message\": {{ JSON.stringify($('Verifica Callback').item.json.error_msg) }} }",
        "options": { "timeout": 10000 }
      }
    },
    {
      "id": "wf7-notifica-fail",
      "name": "Telegram — Reel Fallito ❌",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1250, 850],
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_ADMIN_CHAT_ID }}",
        "text": "=❌ *Reel fallito*\n\nTask ID: {{ $('Verifica Callback').item.json.task_id }}\nErrore: {{ $('Verifica Callback').item.json.error_msg }}\n\nIl record è stato marcato come `failed`. Puoi reimpostare `reel_status = pending` da Supabase per ritentare.",
        "additionalFields": { "parse_mode": "Markdown" }
      }
    },
    {
      "id": "wf7-risposta-webhook",
      "name": "Risposta Webhook (200 OK)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1500, 850],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"received\": true }",
        "options": { "responseCode": 200 }
      }
    },
    {
      "id": "wf7-nessun-reel",
      "name": "Nessun Reel in Coda",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [750, 450],
      "parameters": {},
      "notes": "Coda vuota — il workflow termina silenziosamente. Ritenta al prossimo ciclo (15 min)."
    }
